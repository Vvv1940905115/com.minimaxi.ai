<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.minimaxi.ai" ExtensionBundleName="MiniMax 配音" ExtensionBundleVersion="2.5.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="com.minimaxi.ai.panel" Version="2.5.0" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>

            <Host Name="PPRO" Version="[9.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.minimaxi.ai.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <ScriptPath>./host/index.jsx</ScriptPath>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>MiniMax 配音</Menu>
                    <Geometry>
                        <Size>
                            <Height>600</Height>
                            <Width>800</Width>
                        </Size>
                    </Geometry>
                </UI>
            </DispatchInfo>
            <DispatchInfo Host="PPRO">
               <Resources>
                  <MainPath>./client/index.html</MainPath>
                  <ScriptPath>./host/index.jsx</ScriptPath>
                  <CEFCommandLine>
                     <Parameter>--enable-nodejs</Parameter>
                     <Parameter>--mixed-context</Parameter>
                  </CEFCommandLine>
               </Resources>
               <Lifecycle>
                  <AutoVisible>true</AutoVisible>
               </Lifecycle>
               <UI>
                  <Type>Panel</Type>
                  <Menu>MiniMax 配音</Menu>
                  <Geometry>
                     <Size>
                        <Height>600</Height>
                        <Width>800</Width>
                     </Size>
                  </Geometry>
               </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
